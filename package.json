{
  "name": "@viclafouch/oxc-config",
  "version": "1.0.0-alpha.9",
  "description": "Oxlint and Oxfmt configuration for modern TypeScript, React, Next.js, and React Native projects.",
  "keywords": [
    "config",
    "formatter",
    "linter",
    "nextjs",
    "oxc",
    "oxfmt",
    "oxlint",
    "react",
    "typescript"
  ],
  "homepage": "https://github.com/viclafouch/oxc-config#readme",
  "bugs": {
    "url": "https://github.com/viclafouch/oxc-config/issues"
  },
  "license": "MIT",
  "author": "Victor de la Fouchardiere <victor.delafouchardiere@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viclafouch/oxc-config.git"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./formatting": {
      "types": "./dist/formatting/index.d.ts",
      "import": "./dist/formatting/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "oxlint && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt",
    "prepublishOnly": "tsup",
    "bump": "npm version minor",
    "release": "npm publish",
    "bump:alpha": "npm version prerelease --preid alpha",
    "release:alpha": "npm publish --tag alpha",
    "bump:beta": "npm version prerelease --preid beta",
    "release:beta": "npm publish --tag beta"
  },
  "devDependencies": {
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@tanstack/eslint-plugin-query": ">= 5",
    "eslint-plugin-playwright": ">= 2",
    "eslint-plugin-react-native": ">= 5",
    "eslint-plugin-testing-library": ">= 7",
    "oxfmt": ">= 0.43",
    "oxlint": ">= 1.58",
    "typescript": ">= 5"
  },
  "peerDependenciesMeta": {
    "@tanstack/eslint-plugin-query": {
      "optional": true
    },
    "eslint-plugin-playwright": {
      "optional": true
    },
    "eslint-plugin-react-native": {
      "optional": true
    },
    "eslint-plugin-testing-library": {
      "optional": true
    },
    "oxfmt": {
      "optional": true
    }
  }
}
